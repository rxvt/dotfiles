alias ca='chezmoi apply'
alias cad='chezmoi add'
alias ccd='chezmoi cd'
alias ce='chezmoi edit'
alias cra='chezmoi re-add --verbose'
alias cv='chezmoi verify'
alias gp='git pull'
alias gs='git status'
alias lg='lazygit'
alias v='nvim'
alias vim='nvim'
