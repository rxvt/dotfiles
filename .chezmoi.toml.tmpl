{{- $osid := .chezmoi.os -}}
{{- if hasKey .chezmoi.osRelease "id" -}}
{{-   $osid = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
{{- end -}}

[data]
osid = {{ $osid | quote }}

{{- $fedora_development := promptBoolOnce . "fedora_development" "Is this a Fedora Development host?" }}
fedora_develpment = {{ $fedora_development }}

{{- $work := promptBoolOnce . "work" "Is this a work machine" }}
work = {{ $work }}

{{- $linux_vm_host := promptBoolOnce . "linux_vm_host" "Is this machine a Linux VM Host?" }}
linux_vm_host = {{ $linux_vm_host }}

{{- $linux_development := promptBoolOnce . "linux_development" "Is this a Linux Development host?" }}
linux_development = {{ $linux_development }}
