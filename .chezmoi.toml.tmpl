{{- $osid := .chezmoi.os -}}
{{- if hasKey .chezmoi.osRelease "id" -}}
{{-   $osid = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
{{- end -}}

[data]
osid = {{ $osid | quote }}

{{- $work := promptBoolOnce . "work" "Is this a work machine" }}
work = {{ $work }}

{{- $linux-vm-host := promptBoolOnce . "linux-vm-host" "Is this machine a Linux VM Host?" }}
linux-vm-host = {{ $linux-vm-host }}

{{- $linux-development := promptBoolOnce . "linux-development" "Is this a Linux Development host?" }}
linux-development = {{ $linux-development }}
